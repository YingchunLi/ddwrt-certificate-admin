{
  "name": "OpenVPNConfiguratorForDDWRTAndEdgeRouter",
  "description": "A small Utility to assist with OpenVPN configurations on DD-WRT and EdgeRouter",
  "author": "Yingchun Li<ncepu.lyc@gmail.com>",
  "version": "2.3.3",
  "private": true,
  "license": "MIT",
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "immutability-helper": "^2.6.4",
    "lodash": "^4.18.1",
    "material-ui": "^0.20.0",
    "node-forge": "^1.3.2",
    "node-ssh": "^5.1.2",
    "os-browserify": "^0.3.0",
    "ping": "^0.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "tmp": "^0.2.4"
  },
  "homepage": "./",
  "main": "electron-starter.js",
  "scripts": {
    "start": "nf start -p 5001",
    "react-start": "craco start",
    "electron-start": "node electron-wait-react",
    "electron": "electron .",
    "build": "craco build",
    "test": "craco test --env=jsdom",
    "eject": "react-scripts eject",
    "pack": "electron-builder --dir",
    "dist": "electron-builder -m -w",
    "dist:mac": "electron-builder -m",
    "dist:win": "electron-builder -w",
    "analyze": "source-map-explorer build/static/js/main.*"
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "electron": "^39.8.5",
    "electron-builder": "^24.8.0",
    "foreman": "^2.0.0",
    "process": "^0.11.10",
    "source-map-explorer": "^1.5.0",
    "stream-browserify": "^3.0.0"
  },
  "build": {
    "appId": "org.yingchunli.openVPNConfigAdminForDDWRTAndEdgeRouter",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "build/",
      "electron-starter.js",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron-starter.js"
    },
    "win": {
      "artifactName": "${productName}-${version}.${ext}",
      "target": [
        {
          "target": "portable",
          "arch": [
            "ia32"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.utilities",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "resolutions": {
    "minimatch": "^3.1.2",
    "brace-expansion": "^1.1.12"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
